# Copy to .env and adjust.

PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/lmspro
JWT_SECRET=change_me
# Public URL(s) of the SPA. Optional — when unset, password-reset emails and
# CORS auto-detect the URL from the incoming request (Origin header, then
# same-host fallback), so the link points to whatever IP/domain the user is on.
# Set this only when you want to PIN a specific public URL or allow extra
# origins. Comma-separate to allow multiple (e.g. apex + www).
# CLIENT_URL=http://localhost:8080

# --- Production (e.g. https://lmspro.speshway.site) ---
# Set these on the HOST that runs THIS Node API (Render, VPS, etc.), not only on your laptop:
# NODE_ENV=production
# CLIENT_URL=https://lmspro.speshway.site            # optional; auto-detected otherwise
# MONGO_URI=... (your Atlas or DB URL)
# JWT_SECRET=... (strong random)
# Plus all SMTP_* variables below (same Gmail app password works from any server IP).
# If NODE_ENV is not "development", forgot-password will return 500 when SMTP fails (no fake success).

# Google OAuth — Web application Client ID (same as frontend VITE_GOOGLE_CLIENT_ID)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

ADMIN_EMAIL=admin@learnhub.com
ADMIN_PASSWORD=change_me

# Password reset (Nodemailer). Do NOT use GOOGLE_CLIENT_SECRET here — only a mail password (e.g. Gmail App Password).
# 1) 2-Step Verification: https://myaccount.google.com/security
# 2) App Password: https://myaccount.google.com/apppasswords — SMTP_USER must be that same @gmail.com account.
# Aliases: SMTP_PASSWORD, SMTP_FROM, EMAIL_USER, EMAIL_PASS, EMAIL_HOST (see config.js).
# Gmail: use SMTP_PORT=587 with SMTP_SECURE=false (or omit). Do NOT set SMTP_SECURE=true with 587.
# For SSL on port 465 only: SMTP_PORT=465 and SMTP_SECURE=true.
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxxxxxxxxxxxxxx
# SMTP_PASSWORD=xxxxxxxxxxxxxxxx
# FROM_EMAIL=you@gmail.com
# SMTP_FROM=you@gmail.com
