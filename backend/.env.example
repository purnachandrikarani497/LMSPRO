# Copy to .env and adjust. See README for Google OAuth setup.

PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/lmspro
JWT_SECRET=change_me
# Public URL of the frontend (password-reset links use this). On a real server use https://your-domain.com
CLIENT_URL=http://localhost:8080

# Google OAuth — Web application Client ID (same as frontend VITE_GOOGLE_CLIENT_ID)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

ADMIN_EMAIL=admin@learnhub.com
ADMIN_PASSWORD=change_me

# Password reset (Nodemailer). Do NOT use GOOGLE_CLIENT_SECRET here — only a mail password (e.g. Gmail App Password).
# 1) 2-Step Verification: https://myaccount.google.com/security
# 2) App Password: https://myaccount.google.com/apppasswords — SMTP_USER must be that same @gmail.com account.
# Aliases: SMTP_PASSWORD, SMTP_FROM, EMAIL_USER, EMAIL_PASS, EMAIL_HOST (see config.js).
# Gmail: use SMTP_PORT=587 with SMTP_SECURE=false (or omit). Do NOT set SMTP_SECURE=true with 587.
# For SSL on port 465 only: SMTP_PORT=465 and SMTP_SECURE=true.
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxxxxxxxxxxxxxx
# SMTP_PASSWORD=xxxxxxxxxxxxxxxx
# FROM_EMAIL=you@gmail.com
# SMTP_FROM=you@gmail.com
