# API base for fetch(). Default /api works when the host reverse-proxies /api to the Node backend.
# VITE_API_BASE_URL=/api
# If the API is on another origin, set full URL (rebuild after change):
# VITE_API_BASE_URL=https://lmspro.speshway.site/api

# Google Sign-In — Web client ID (same as backend GOOGLE_CLIENT_ID).
# In Google Cloud Console add Authorized JavaScript origins: https://your-domain.com
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
